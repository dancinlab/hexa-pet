#!hexa strict
// hexa-pet/verify/real_limits_anchor.hexa — real-limits-first anchor.
//
// Per LATTICE_POLICY.md §1.3 rule 2: each project's verify must use at
// least one anchor from §1.2 (Shannon · Kolmogorov · Bekenstein · c · ℏ ·
// k · Stefan-Boltzmann · Carnot · ASML throughput · ERCOT · etc.) and
// at least one engineering/industry threshold.
//
// For hexa-pet (consumer-pet substrate) the engineering/industry
// thresholds are:
//   • veterinary medicine — AVMA / AAHA guidelines
//   • pet nutrition       — AAFCO 2024 nutrient profiles + NRC 2006
//   • pet pharmaceuticals — FDA-CVM (Center for Veterinary Medicine)
//   • plus material/behaviour anchors per LIMIT_BREAKTHROUGH.md L1–L10:
//       L1 cat taurine NRC 2006 / Knopf 1978 (HARD)
//       L2 AAFCO essential amino acid panel (HARD)
//       L3 Wyoming Na-bentonite swell 15–20× Grim 1978 (HARD per-material)
//       L4 nepetalactone vapor pressure / catnip Todd 1962 (HARD per-species)
//       L5 canine bite 230–1,400 N Ellis 2008 (HARD per-breed)
//       L8 ANSI Z136.1 laser MPE Class IIIa < 5 mW (HARD safety)
//
// Honesty (raw#10 C3): pet-medical claims STRICTLY UNPROVEN without
// veterinary IRB. This repo is consumer-product engineering, not
// veterinary medicine — "consult licensed veterinarian" for any clinical
// decision. Pet-food/pharma/retail brands (Hill's, Royal Canin, Purina,
// Zoetis, Boehringer, Elanco, Petco, Chewy) use THEIR OWN specs —
// no lattice-fit per LATTICE_POLICY §3.3.

let HOME = env("HOME")
let HEXA_PET_ROOT_ENV = env("HEXA_PET_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_PET_ROOT_ENV.len() > 0 { return HEXA_PET_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-pet"
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

fn _file_contains(p: str, needle: str) -> bool {
    let cmd = "grep -F " + shq(needle) + " " + shq(p) + " >/dev/null 2>&1 && echo yes || echo no"
    let r = exec(cmd).trim()
    return r == "yes"
}

fn main() {
    let root = _resolve_root()
    println("hexa-pet/verify/real_limits_anchor — real-limits-first check")
    println("  root: " + root)
    println("")
    println("  policy: LATTICE_POLICY §1.3 rule 2 — at least 1 real limit anchor required")
    println("  source: LIMIT_BREAKTHROUGH.md (Wave M, consumer-pet substrate audit)")
    println("  engineering thresholds: AVMA/AAHA + AAFCO + FDA-CVM")
    println("")

    let mut ok = 0
    let mut bad = 0

    // 1. Audit file must exist.
    let audit = root + "/LIMIT_BREAKTHROUGH.md"
    if _file_exists(audit) {
        println("  [PASS] LIMIT_BREAKTHROUGH.md present")
        ok = ok + 1
    } else {
        println("  [FAIL] LIMIT_BREAKTHROUGH.md missing (abs: " + audit + ")")
        bad = bad + 1
    }

    // 2. Audit must reference canonical pet-domain HARD/SOFT walls (L1–L10).
    let anchors = [
        ["L1 cat taurine NRC 2006 / Knopf 1978",   "taurine"],
        ["L2 AAFCO essential amino acid panel",     "AAFCO"],
        ["L3 Wyoming Na-bentonite swell 15-20x",   "bentonite"],
        ["L4 nepetalactone catnip Todd 1962",       "nepetalactone"],
        ["L5 canine bite Ellis 2008",               "bite force"],
        ["L8 ANSI Z136.1 laser MPE",                "ANSI Z136"],
        ["FDA-CVM regulatory reference",            "FDA-CVM"],
        ["NRC 2006 nutrient requirements",          "NRC"],
    ]
    for a in anchors {
        let label = a[0]
        let needle = a[1]
        if _file_contains(audit, needle) {
            println("  [PASS] anchor referenced: " + label)
            ok = ok + 1
        } else {
            println("  [FAIL] anchor missing: " + label + " (needle: '" + needle + "')")
            bad = bad + 1
        }
    }

    // 3. Honesty caveats: pet-medical claims STRICTLY UNPROVEN without
    //    veterinary IRB. "Consult licensed veterinarian" for clinical
    //    decisions. (raw#10 C3 + LATTICE_POLICY §3.3.)
    let caveats = [
        ["consumer-product, not veterinary medicine",  "consumer-product"],
        ["AAFCO is not FDA approval caveat",            "AAFCO is not FDA"],
        ["lattice = organising vocabulary only",        "organising vocabulary"],
    ]
    for u in caveats {
        let label = u[0]
        let needle = u[1]
        if _file_contains(audit, needle) {
            println("  [PASS] honesty caveat preserved: " + label)
            ok = ok + 1
        } else {
            println("  [FAIL] honesty caveat MISSING: " + label)
            bad = bad + 1
        }
    }

    println("")
    println("  anchors verified: " + str(ok) + "  failures: " + str(bad))
    if bad > 0 {
        println("__HEXA_PET_REAL_LIMITS_ANCHOR__ FAIL")
        exit(1)
    }
    println("__HEXA_PET_REAL_LIMITS_ANCHOR__ PASS")
}
