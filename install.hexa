// install.hexa — hx build hook for hexa-pet.
//
// Invoked by `hx install hexa-pet` (hexa-lang package manager) right after
// the GitHub checkout (or symlink from /Users/ghost/core/hexa-pet) lands in
// $HX_PKG_DIR. hx passes:
//   HX_PKG_DIR     — absolute path to the package root
//   HX_BIN_DIR     — ~/.hx/bin
//   HX_PKG_NAME    — "hexa-pet"
//   HX_HOOK_PHASE  — "pre" | "post" | "both" (default: "both")
//
// Mirrors hexa-bio/install.hexa pattern (sister substrate, 2026-05-04).
//
// Responsibilities (each idempotent, raw#9 STRICT — hexa-only orchestration):
//   1. Pre-install: NO external deps (pure spec substrate). Always exit 0.
//   2. Post-install: run `hexa-pet selftest` via the freshly-staged
//      cli/hexa-pet.hexa. Selftest output captured; non-PASS = warn-only
//      (not a blocker — placeholder dispatcher always passes 5-verb count).
//
// raw#9 hexa-only, raw#11 snake_case, raw#15 no-hardcode.
// raw#10 honest C3: see hexa-pet/README.md "Status" section.

fn run_quick_selftest(root: str) -> bool {
    let cli = root + "/cli/hexa-pet.hexa"
    let exists = exec("[ -f \"" + cli + "\" ] && echo y || echo n").trim()
    if exists != "y" {
        eprintln("[hexa-pet/install] WARN: cli/hexa-pet.hexa missing — skip selftest")
        return false
    }
    println("[hexa-pet/install] [post] running quick selftest (5-verb count check)")
    let cmd = "HEXA_PET_ROOT=\"" + root + "\" hexa run \"" + cli + "\" selftest 2>&1"
    let raw = exec(cmd)
    if raw.contains("__HEXA_PET_SELFTEST__ PASS") {
        println("[hexa-pet/install]   selftest PASS — 5/5 verbs present")
        return true
    }
    eprintln("[hexa-pet/install] WARN: selftest non-PASS (warn-only, not a blocker)")
    eprintln("  hint: missing verb spec doc — see README §Status")
    return false
}

fn main() -> void {
    let mut root = env("HX_PKG_DIR")
    if root == "" { root = exec("pwd").trim() }
    let phase = env("HX_HOOK_PHASE")
    let mut p = phase
    if p == "" { p = "both" }
    println("[hexa-pet/install] HX_PKG_DIR=" + root + " phase=" + p)

    let entry = root + "/cli/hexa-pet.hexa"
    let entry_ok = exec("[ -f \"" + entry + "\" ] && echo y || echo n").trim()
    if entry_ok != "y" {
        eprintln("[hexa-pet/install] ERROR: canonical entry missing: " + entry)
        exit(1)
    }
    println("[hexa-pet/install] canonical entry OK: cli/hexa-pet.hexa")

    if p == "pre" || p == "both" {
        println("[hexa-pet/install] [pre] no external deps (pure spec substrate) — skip")
    }

    if p == "post" || p == "both" {
        let _ = run_quick_selftest(root)  // warn-only
    }

    println("[hexa-pet/install] done — hx will generate " + env("HX_BIN_DIR") + "/hexa-pet shim")
}
